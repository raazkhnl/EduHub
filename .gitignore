# Dependencies
node_modules/
.pnp/
.pnp.js
.yarn/

# Build
build/
.docusaurus/
.cache-loader/

# Misc
.DS_Store
Thumbs.db
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Migration scratch (raw drops before they enter the taxonomy)
incoming/
files*

# Bundle manifest — regenerated by plugins/bundle-manifest at build/dev time
/static/_bundle/

# PWA icons + social card — generated by scripts/generate-pwa-icons.mjs at prebuild
/static/img/icons/icon-*.png
/static/img/icons/maskable-*.png
/static/img/icons/apple-touch-icon.png
/static/img/social-card.png

# OS
*.swp
*.swo
