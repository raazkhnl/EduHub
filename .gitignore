# ─── Dependencies ──────────────────────────────────────────────────────────
node_modules/
.pnp/
.pnp.js
.yarn/

# ─── Build output ──────────────────────────────────────────────────────────
build/
.docusaurus/
.cache-loader/
.cache/
*.tsbuildinfo

# ─── Environment / secrets ─────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Logs ──────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Editor / OS ───────────────────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ─── Source-content drop zones ─────────────────────────────────────────────
# Raw notes live here before being migrated into the docs/ taxonomy. They
# can be large (~hundreds of MB) and frequently overwritten — keep them
# out of git. The `files*` glob covers `files (1)`, `files (2)`,
# `files msncs-study-notes/`, etc.
incoming/
files*
*.bak

# ─── Generated assets ──────────────────────────────────────────────────────
# Bundle manifest — regenerated by plugins/bundle-manifest at build/dev time.
/static/_bundle/

# PWA icons + social card — generated by scripts/generate-pwa-icons.mjs.
/static/img/icons/icon-*.png
/static/img/icons/maskable-*.png
/static/img/icons/apple-touch-icon.png
/static/img/social-card.png

# Migration / scaffold intermediate files
/tmp/
*.orig
